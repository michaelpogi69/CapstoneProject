<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Outer Circle -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="#2563eb" stroke-width="12"/>
  
  <!-- Mountains -->
  <path d="M 40 120 L 65 70 L 80 95 L 100 50 L 120 95 L 135 70 L 160 120" fill="none" stroke="#2563eb" stroke-width="10" stroke-linecap="round" stroke-linejoin="round"/>
  
  <!-- Pine Tree -->
  <g>
    <polygon points="50,90 45,100 55,100" fill="#2563eb"/>
    <polygon points="50,100 40,115 60,115" fill="#2563eb"/>
    <polygon points="50,110 35,130 65,130" fill="#2563eb"/>
    <rect x="48" y="130" width="4" height="15" fill="#2563eb"/>
  </g>
  
  <!-- Jeepney/Bus -->
  <g>
    <!-- Body -->
    <rect x="80" y="135" width="50" height="30" rx="3" fill="none" stroke="#2563eb" stroke-width="8"/>
    
    <!-- Windows -->
    <rect x="88" y="142" width="10" height="8" fill="none" stroke="#2563eb" stroke-width="2"/>
    <rect x="105" y="142" width="10" height="8" fill="none" stroke="#2563eb" stroke-width="2"/>
    <rect x="122" y="142" width="10" height="8" fill="none" stroke="#2563eb" stroke-width="2"/>
    
    <!-- Wheels -->
    <circle cx="92" cy="167" r="8" fill="none" stroke="#2563eb" stroke-width="6"/>
    <circle cx="128" cy="167" r="8" fill="none" stroke="#2563eb" stroke-width="6"/>
  </g>
</svg>